{
  "name": "@sun-asterisk-internal/sun-design-system",
  "private": false,
  "version": "1.0.9",
  "description": "Sun design system - A React component library built with TypeScript and Tailwind CSS.",
  "author": "Sun Asterisk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sun-asterisk-internal/sun-design-system.git"
  },
  "homepage": "https://github.com/sun-asterisk-internal/sun-design-system#readme",
  "bugs": {
    "url": "https://github.com/sun-asterisk-internal/sun-design-system/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./styles": "./dist/index.css",
    "./global.css": "./dist/global.css",
    "./button": {
      "types": "./dist/types/components/button/index.d.ts",
      "import": "./dist/esm/components/button/index.js"
    },
    "./input": {
      "types": "./dist/types/components/input/index.d.ts",
      "import": "./dist/esm/components/input/index.js"
    },
    "./text-field": {
      "types": "./dist/types/components/textField/index.d.ts",
      "import": "./dist/esm/components/textField/index.js"
    },
    "./textarea": {
      "types": "./dist/types/components/textarea/index.d.ts",
      "import": "./dist/esm/components/textarea/index.js"
    },
    "./textarea-field": {
      "types": "./dist/types/components/textareaField/index.d.ts",
      "import": "./dist/esm/components/textareaField/index.js"
    },
    "./radio-group": {
      "types": "./dist/types/components/radioGroup/index.d.ts",
      "import": "./dist/esm/components/radioGroup/index.js"
    },
    "./badge": {
      "types": "./dist/types/components/badge/index.d.ts",
      "import": "./dist/esm/components/badge/index.js"
    },
    "./divider": {
      "types": "./dist/types/components/divider/index.d.ts",
      "import": "./dist/esm/components/divider/index.js"
    },
    "./switch": {
      "types": "./dist/types/components/switch/index.d.ts",
      "import": "./dist/esm/components/switch/index.js"
    },
    "./tooltip": {
      "types": "./dist/types/components/tooltip/index.d.ts",
      "import": "./dist/esm/components/tooltip/index.js"
    },
    "./tab": {
      "types": "./dist/types/components/tab/index.d.ts",
      "import": "./dist/esm/components/tab/index.js"
    },
    "./snackbar": {
      "types": "./dist/types/components/snackbar/index.d.ts",
      "import": "./dist/esm/components/snackbar/index.js"
    },
    "./modal": {
      "types": "./dist/types/components/modal/index.d.ts",
      "import": "./dist/esm/components/modal/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "typescript",
    "tailwindcss",
    "radix-ui"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "build:tokens": "node scripts/build-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "package:check": "npm pack --dry-run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "react-icons": "^5.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.1.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/js": "^9.35.0",
    "@storybook/addon-a11y": "^9.1.7",
    "@storybook/addon-docs": "^9.1.7",
    "@storybook/addon-vitest": "^9.1.7",
    "@storybook/react-vite": "^9.1.7",
    "@tailwindcss/vite": "^4.1.15",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/vite-plugin": "^5.1.1",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "date-fns": "^4.1.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.1.7",
    "framer-motion": "^12.23.15",
    "globals": "^16.4.0",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-datepicker": "^8.7.0",
    "react-dom": "^19.1.1",
    "storybook": "^9.1.7",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^4.1.15",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "uuid": "^13.0.0",
    "vite": "^7.1.6",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
